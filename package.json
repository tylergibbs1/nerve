{
  "name": "nerve-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "typecheck": "for p in packages/* examples/*; do (cd $p && bunx tsc -p . --noEmit) || exit 1; done",
    "build": "bun run --filter './packages/*' build"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ]
}
