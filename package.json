{
  "name": "nerve-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "typecheck": "for p in packages/* examples/*; do (cd $p && bunx tsc -p . --noEmit) || exit 1; done",
    "build": "bun run --filter './packages/*' build"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^25.9.2",
    "@types/pngjs": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.9",
    "fast-check": "^4.8.0",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  },
  "workspaces": [
    "packages/*",
    "examples/*",
    "eval-corpus"
  ]
}
