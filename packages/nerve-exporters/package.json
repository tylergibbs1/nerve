{
  "name": "@grayhaven/nerve-exporters",
  "version": "0.2.1",
  "type": "module",
  "sideEffects": false,
  "description": "Grayhaven Nerve exporters: CSV, SVG, JSON, and zip manufacturing outputs generated from HIR.",
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@grayhaven/nerve": "workspace:*",
    "effect": "^3.16.0",
    "fflate": "^0.8.2",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@grayhaven/nerve-compiler": "workspace:*",
    "@grayhaven/nerve-connectors": "workspace:*",
    "@grayhaven/nerve-rules": "workspace:*",
    "@types/node": "^25.9.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tylergibbs1/nerve.git",
    "directory": "packages/nerve-exporters"
  },
  "homepage": "https://github.com/tylergibbs1/nerve#readme"
}
