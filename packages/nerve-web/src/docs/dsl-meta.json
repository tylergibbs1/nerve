{
  "builders": [
    {
      "name": "harness",
      "signature": "harness(id: string, props: HarnessProps)",
      "doc": "Define a harness — the root design object and default export of a `.harness.ts` file."
    },
    {
      "name": "connector",
      "signature": "connector(ref: string, part: ConnectorPart, opts: { readonly pins: PinAssignments; readonly terminals?: PinPartAssignment; readonly seals?: PinPartAssignment })",
      "doc": "Place a connector in the harness: `connector(\"J1\", MolexMicroFit[\"43025-0800\"], { pins: {...}, terminals: \"43030-0007\" })`."
    },
    {
      "name": "wire",
      "signature": "wire(id: string, from: EndpointInput, to: EndpointInput, props: WireProps = {})",
      "doc": "Define a wire between two endpoints:\n`wire(\"W1\", j1.pin(1), m1.pin(1), { gauge: \"18AWG\", ... })` or\n`wire(\"W5\", j1.pin(2), s1, {...})` where `s1` is a splice."
    },
    {
      "name": "splice",
      "signature": "splice(id: string, props: SpliceProps = {})",
      "doc": "Define a splice node: `splice(\"S1\", { type: \"crimp\", branch: \"main\", location: 120 })`."
    },
    {
      "name": "cable",
      "signature": "cable(id: string, props: CableProps = {})",
      "doc": "Define a multi-conductor cable that wires can belong to via `cable`/`conductor` props."
    },
    {
      "name": "branch",
      "signature": "branch(id: string, props: BranchProps)",
      "doc": "Define a physical branch through the harness: `branch(\"main\", { path: [j1, m1], ... })`."
    },
    {
      "name": "label",
      "signature": "label(id: string, props: LabelProps)",
      "doc": "Define a label: `label(\"L1\", { text: \"MOTOR CTRL A\", attachTo: \"main\", ... })`."
    },
    {
      "name": "variant",
      "signature": "variant(base: HarnessDesign, opts: VariantOptions)",
      "doc": "Derive a variant: `variant(base, { id: \"...-long\", wires: { override: { W1: { length: 800 } } } })`."
    },
    {
      "name": "rule",
      "signature": "rule(name: string, run: (ctx: RuleContext) => void, options: RuleOptions = {})",
      "doc": "Define a validation rule: `rule(\"require-can-pairs-twisted\", (ctx) => {...})`."
    },
    {
      "name": "defineConfig",
      "signature": "defineConfig(config: NerveConfig)",
      "doc": ""
    }
  ],
