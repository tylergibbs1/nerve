{
  "name": "@grayhaven/nerve-rules",
  "version": "6.2.0",
  "type": "module",
  "description": "Built-in validation and linting rules for Grayhaven Nerve.",
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@grayhaven/nerve": "workspace:*"
  },
  "devDependencies": {
    "@grayhaven/nerve-connectors": "workspace:*",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "mutation": "stryker run"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tylergibbs1/nerve.git",
    "directory": "packages/nerve-rules"
  },
  "homepage": "https://github.com/tylergibbs1/nerve#readme"
}
