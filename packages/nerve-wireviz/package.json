{
  "name": "@grayhaven/nerve-wireviz",
  "version": "6.1.1",
  "type": "module",
  "description": "WireViz YAML import/export adapter for Grayhaven Nerve (PRD \u00a727.2).",
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@grayhaven/nerve": "workspace:*",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tylergibbs1/nerve.git",
    "directory": "packages/nerve-wireviz"
  },
  "homepage": "https://github.com/tylergibbs1/nerve#readme"
}
