{
  "name": "@grayhaven/nerve-connectors",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Verified connector library for Grayhaven Nerve.",
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@grayhaven/nerve": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  }
}
