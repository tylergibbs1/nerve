{
  "name": "@grayhaven/nerve-cli",
  "version": "6.1.1",
  "type": "module",
  "description": "Deterministic harness import, review, evaluation, validation, and export for local and CI workflows.",
  "bin": {
    "nerve": "./bin/nerve.js"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@grayhaven/nerve": "workspace:*",
    "@grayhaven/nerve-compiler": "workspace:*",
    "@grayhaven/nerve-connectors": "workspace:*",
    "@grayhaven/nerve-eval": "workspace:*",
    "@grayhaven/nerve-exporters": "workspace:*",
    "@grayhaven/nerve-importers": "workspace:*",
    "@grayhaven/nerve-rules": "workspace:*",
    "@grayhaven/nerve-wireviz": "workspace:*",
    "@resvg/resvg-js": "^2.6.2",
    "effect": "^3.16.0",
    "jiti": "^2.4.2",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/pngjs": "^6.0.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tylergibbs1/nerve.git",
    "directory": "packages/nerve-cli"
  },
  "homepage": "https://github.com/tylergibbs1/nerve#readme"
}
